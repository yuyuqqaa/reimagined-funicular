from flask import Flask, request, Response
import requests
from urllib.parse import urljoin, urlparse
import re

app = Flask(__name__)

# 修改开关：True启用修改，False禁用修改
ENABLE_MODIFICATION = True

@app.route('/', defaults={'path': ''})
@app.route('/<path:path>')
def proxy(path):
    url = request.url
    
    if not path:
        return "请输入 / 后面的链接", 400
    
    # 构建目标URL
    target_url_str = path + ('?' + request.query_string.decode() if request.query_string else '')
    
    # 检查是否包含协议
    has_protocol = target_url_str.startswith(('http://', 'https://'))
    
    if not has_protocol:
        actual_url_str = detect_protocol(target_url_str)
    else:
        actual_url_str = target_url_str
    
    try:
        # 检查是否为 M3U8 文件请求
        is_m3u8_request = actual_url_str.lower().endswith('.m3u8') or '.m3u8?' in actual_url_str.lower()
        
        if is_m3u8_request:
            return handle_m3u8_request(actual_url_str, url)
        
        # 创建请求到目标网站
        headers = {key: value for key, value in request.headers if key.lower() != 'host'}
        
        resp = requests.request(
            method=request.method,
            url=actual_url_str,
            headers=headers,
            data=request.get_data(),
            cookies=request.cookies,
            allow_redirects=True,
            stream=True
        )
        
        # 当修改开关开启且是HTML内容时进行DOM重写
        if ENABLE_MODIFICATION and 'text/html' in resp.headers.get('content-type', ''):
            return handle_html_rewrite(resp, url)
        
        # 返回原始响应
        response_headers = [(name, value) for name, value in resp.headers.items()]
        return Response(resp.content, status=resp.status_code, headers=response_headers)
        
    except Exception as error:
        return f"请求失败: {str(error)}", 500

def detect_protocol(domain):
    """检测使用HTTP还是HTTPS协议"""
    try:
        https_url = f"https://{domain}"
        response = requests.head(https_url, allow_redirects=False, timeout=5)
        if response.status_code < 400:
            return https_url
    except:
        pass
    return f"http://{domain}"

def handle_m3u8_request(m3u8_url, original_url):
    """特殊处理 M3U8 文件请求"""
    try:
        # 以纯文本方式请求 M3U8 文件
        headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
            'Accept': '*/*',
            'Accept-Language': 'en-US,en;q=0.5',
            'Accept-Encoding': 'identity'  # 避免压缩
        }
        
        resp = requests.get(m3u8_url, headers=headers, timeout=30, stream=False)
        resp.raise_for_status()
        
        # 获取 M3U8 内容
        m3u8_content = resp.text
        
        # 解析原始 URL 获取基础路径
        parsed_original = urlparse(original_url)
        mirror_base = f"{parsed_original.scheme}://{parsed_original.netloc}{parsed_original.path}"
        
        # 处理 M3U8 文件中的相对路径
        def replace_m3u8_links(line):
            line = line.strip()
            # 跳过注释和空行
            if line.startswith('#') or not line:
                return line
            
            # 如果已经是绝对URL，直接返回
            if line.startswith(('http://', 'https://')):
                return line
            
            # 如果是相对路径，转换为绝对路径
            if line.startswith('/'):
                # 相对于根目录的绝对路径
                parsed_m3u8 = urlparse(m3u8_url)
                base_url = f"{parsed_m3u8.scheme}://{parsed_m3u8.netloc}"
                return urljoin(base_url, line)
            else:
                # 相对于当前 M3U8 文件的相对路径
                return urljoin(m3u8_url, line)
        
        # 处理每一行
        lines = m3u8_content.split('\n')
        processed_lines = []
        
        for line in lines:
            if line.strip() and not line.strip().startswith('#'):
                # 这是可能是URL的行
                processed_line = replace_m3u8_links(line)
                # 将URL转换为代理URL
                if processed_line.startswith(('http://', 'https://')):
                    # 将目标URL编码到代理路径中
                    encoded_url = processed_line.replace('://', '/').replace('//', '/')
                    processed_line = f"{mirror_base}/{encoded_url}"
                processed_lines.append(processed_line)
            else:
                processed_lines.append(line)
        
        modified_content = '\n'.join(processed_lines)
        
        # 设置响应头，模拟 audio/x-mpegurl
        response_headers = {
            'Content-Type': 'audio/x-mpegurl',
            'Access-Control-Allow-Origin': '*',
            'Access-Control-Allow-Headers': '*',
            'Access-Control-Allow-Methods': 'GET, HEAD, OPTIONS',
            'Content-Length': str(len(modified_content.encode('utf-8')))
        }
        
        return Response(modified_content, status=200, headers=response_headers)
        
    except Exception as e:
        return f"M3U8请求失败: {str(e)}", 500

def handle_html_rewrite(response, original_url):
    """处理HTML重写，修改相对链接"""
    text = response.text
    mirror_base = f"{request.scheme}://{request.host}{request.path}"
    
    # 替换相对链接为绝对链接
    def replace_relative_links(match):
        prefix = match.group(1)
        path = match.group(2)
        # 如果路径已经是绝对路径或包含协议，则不替换
        if path.startswith(('http://', 'https://', '//')):
            return match.group(0)
        # 确保路径不以斜杠开头
        if path.startswith('/'):
            path = path[1:]
        return f'{prefix}{mirror_base}/{path}'
    
    # 使用正则表达式替换链接
    modified_text = re.sub(
        r'(<a[^>]+href=["\'])(?!https?://)([^"\']+)',
        replace_relative_links,
        text,
        flags=re.IGNORECASE
    )
    
    modified_text = re.sub(
        r'(<img[^>]+src=["\'])(?!https?://)([^"\']+)',
        replace_relative_links,
        modified_text,
        flags=re.IGNORECASE
    )
    
    # 移除可能阻止资源加载的安全策略头
    headers = dict(response.headers)
    headers_to_remove = ['content-security-policy', 'Content-Security-Policy']
    for header in headers_to_remove:
        if header in headers:
            del headers[header]
    
    return Response(modified_text, status=response.status_code, headers=headers)

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)
